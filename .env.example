# PostgreSQL Connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=library_db
PGUSER=library_user
PGPASSWORD=change_me
PGSSLMODE=prefer

# Session / Auth
JWT_SECRET=replace-with-strong-secret
USE_HTTPS=false

# Next.js runtime
NODE_ENV=development
NEXT_PUBLIC_GPT_IMAGES_BASE=/static/

# Google Custom Search Engine (optional)
GOOGLE_CSE_KEY=your-google-cse-key
GOOGLE_CSE_CX=your-google-cse-cx

# AI search service
AI_SEARCH_BASE=http://localhost:8123/ai-search
OPENAI_API_KEY=your-openai-key
OPENAI_EMBED_MODEL=text-embedding-3-large

# Bitrix24 integration
B24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/example/
B24_PORTAL_ORIGIN=https://your-portal.bitrix24.ru
B24_UF_INN_FIELDS=UF_CRM_XXXXXXXXX,UF_CRM_YYYYYYYYY
B24_UF_INN_FIELD=UF_CRM_1705778266246
B24_COLOR_UF_FIELD=UF_CRM_1743187724272

# Bitrix database replica (optional)
BITRIX_DB_HOST=localhost
BITRIX_DB_PORT=5432
BITRIX_DB_NAME=bitrix
BITRIX_DB_USER=bitrix_user
BITRIX_DB_PASSWORD=change_me
BITRIX_DB_SSL=disable

# Browser-level UI smoke for AI Analysis (optional)
AI_ANALYSIS_UI_SMOKE_BASE_URL=https://ai.irbistech.com
AI_ANALYSIS_UI_SMOKE_LOGIN=
AI_ANALYSIS_UI_SMOKE_PASSWORD=
AI_ANALYSIS_UI_SMOKE_TIMEOUT_MS=30000
AI_ANALYSIS_UI_SMOKE_HEADLESS=true
AI_ANALYSIS_UI_SMOKE_REQUIRE_AUTH=false
AI_ANALYSIS_UI_SMOKE_CAPTURE=true
AI_ANALYSIS_UI_SMOKE_ARTIFACT_DIR=artifacts/ai-analysis-ui-smoke

# Browser-level UI QA artifact capture for 1way/2way/3way/okved cases (optional)
AI_ANALYSIS_UI_QA_BASE_URL=https://ai.irbistech.com
# Filling AI_ANALYSIS_UI_QA_LOGIN/PASSWORD (or fallback AI_ANALYSIS_UI_SMOKE_LOGIN/PASSWORD)
# also allows automatic enablement of ai-analysis-ui-qa-healthcheck.timer by the installer.
AI_ANALYSIS_UI_QA_LOGIN=
AI_ANALYSIS_UI_QA_PASSWORD=
AI_ANALYSIS_UI_QA_TIMEOUT_MS=60000
AI_ANALYSIS_UI_QA_HEADLESS=true
AI_ANALYSIS_UI_QA_CAPTURE=true
AI_ANALYSIS_UI_QA_ARTIFACT_DIR=artifacts/ai-analysis-ui-qa
AI_ANALYSIS_UI_QA_OKVED_INN=1841109992
AI_ANALYSIS_UI_QA_2WAY_INN=6320002223
AI_ANALYSIS_UI_QA_3WAY_INN=3444070534

# Standalone authenticated browser QA healthcheck for cron/systemd monitoring (optional)
AI_ANALYSIS_UI_QA_HEALTH_BASE_URL=http://127.0.0.1:8090
AI_ANALYSIS_UI_QA_HEALTH_TIMEOUT_MS=60000
AI_ANALYSIS_UI_QA_HEALTH_HEADLESS=true
AI_ANALYSIS_UI_QA_HEALTH_CAPTURE=true
AI_ANALYSIS_UI_QA_HEALTH_ALERT_WEBHOOK_URL=
AI_ANALYSIS_UI_QA_HEALTH_ALERT_ON_RECOVERY=true
AI_ANALYSIS_UI_QA_HEALTH_STATE_FILE=/var/lib/library/ai-analysis-ui-qa-health-state.json
AI_ANALYSIS_UI_QA_HEALTH_ARTIFACT_DIR=/var/lib/library/ai-analysis-ui-qa-health

# Standalone browser-level UI smoke healthcheck for cron/systemd monitoring (optional)
AI_ANALYSIS_UI_SMOKE_HEALTH_BASE_URL=http://127.0.0.1:8090
AI_ANALYSIS_UI_SMOKE_HEALTH_TIMEOUT_MS=60000
AI_ANALYSIS_UI_SMOKE_HEALTH_ALERT_WEBHOOK_URL=
AI_ANALYSIS_UI_SMOKE_HEALTH_ALERT_ON_RECOVERY=true
AI_ANALYSIS_UI_SMOKE_HEALTH_STATE_FILE=/var/lib/library/ai-analysis-ui-smoke-health-state.json
AI_ANALYSIS_UI_SMOKE_HEALTH_ARTIFACT_DIR=/var/lib/library/ai-analysis-ui-smoke-health

# Rollout helper toggle for browser smoke on the current VPS layout (optional)
LIBRARY_ROLLOUT_ALLOWED_APP_DIR=/opt/library/app
LIBRARY_ROLLOUT_MONITORING_ENV_FILE=/etc/default/library-monitoring
LIBRARY_ROLLOUT_UI_SMOKE_MODE=auto
LIBRARY_ROLLOUT_UI_QA_MODE=auto
LIBRARY_ROLLOUT_INSTALL_SYSTEMD=auto
LIBRARY_ROLLOUT_SKIP_INSTALL=0

# Service-chain health smoke (optional)
LIBRARY_HEALTH_BASE_URL=https://ai.irbistech.com

# AI Analysis acceptance QA for 1way/2way/3way/okved trace semantics (optional)
AI_ANALYSIS_ACCEPTANCE_BASE_URL=https://ai.irbistech.com
AI_ANALYSIS_ACCEPTANCE_OKVED_INN=1841109992
AI_ANALYSIS_ACCEPTANCE_2WAY_INN=6320002223
AI_ANALYSIS_ACCEPTANCE_3WAY_INN=3444070534
AI_ANALYSIS_ACCEPTANCE_ARTIFACT_DIR=artifacts/ai-analysis-acceptance-qa

# Standalone AI Analysis trace acceptance healthcheck for cron/systemd monitoring (optional)
AI_ANALYSIS_ACCEPTANCE_HEALTH_BASE_URL=http://127.0.0.1:8090
AI_ANALYSIS_ACCEPTANCE_HEALTH_TIMEOUT_MS=15000
AI_ANALYSIS_ACCEPTANCE_HEALTH_ALERT_WEBHOOK_URL=
AI_ANALYSIS_ACCEPTANCE_HEALTH_ALERT_ON_RECOVERY=true
AI_ANALYSIS_ACCEPTANCE_HEALTH_STATE_FILE=/var/lib/library/ai-analysis-acceptance-health-state.json
AI_ANALYSIS_ACCEPTANCE_HEALTH_ARTIFACT_DIR=/var/lib/library/ai-analysis-acceptance-health

# Standalone service-chain healthcheck for cron/systemd monitoring (optional)
LIBRARY_SYSTEM_HEALTH_URL=http://127.0.0.1:8090/api/health
LIBRARY_SYSTEM_HEALTH_TIMEOUT_MS=10000
LIBRARY_SYSTEM_HEALTH_ALERT_WEBHOOK_URL=
LIBRARY_SYSTEM_HEALTH_ALERT_ON_RECOVERY=true
LIBRARY_SYSTEM_HEALTH_STATE_FILE=/var/lib/library/library-system-health-state.json

# systemd installer for monitoring units (optional)
LIBRARY_SYSTEMD_TARGET_DIR=/etc/systemd/system
LIBRARY_SYSTEMD_UNITS=library-system-healthcheck.service library-system-healthcheck.timer ai-analysis-acceptance-healthcheck.service ai-analysis-acceptance-healthcheck.timer ai-analysis-ui-smoke-healthcheck.service ai-analysis-ui-smoke-healthcheck.timer ai-analysis-ui-qa-healthcheck.service ai-analysis-ui-qa-healthcheck.timer
LIBRARY_SYSTEMD_ENV_TEMPLATE_SOURCE=deploy/systemd/library-monitoring.env.example
LIBRARY_SYSTEMD_ENV_TEMPLATE_TARGET=/etc/default/library-monitoring.example
LIBRARY_SYSTEMD_ENV_FILE_TARGET=/etc/default/library-monitoring
LIBRARY_SYSTEMD_BOOTSTRAP_ENV_FILE=false
LIBRARY_SYSTEMD_ENABLE_TIMERS=true
LIBRARY_SYSTEMD_SKIP_SYSTEMCTL=false
