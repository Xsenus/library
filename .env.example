# PostgreSQL Connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=library_db
PGUSER=library_user
PGPASSWORD=change_me
PGSSLMODE=prefer

# Session / Auth
JWT_SECRET=replace-with-strong-secret
USE_HTTPS=false

# Next.js runtime
NODE_ENV=development
NEXT_PUBLIC_GPT_IMAGES_BASE=/static/

# Google Custom Search Engine (optional)
GOOGLE_CSE_KEY=your-google-cse-key
GOOGLE_CSE_CX=your-google-cse-cx

# AI search service
AI_SEARCH_BASE=http://localhost:8123/ai-search
OPENAI_API_KEY=your-openai-key
OPENAI_EMBED_MODEL=text-embedding-3-large

# Bitrix24 integration
B24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/example/
B24_PORTAL_ORIGIN=https://your-portal.bitrix24.ru
B24_UF_INN_FIELDS=UF_CRM_XXXXXXXXX,UF_CRM_YYYYYYYYY
B24_UF_INN_FIELD=UF_CRM_1705778266246
B24_COLOR_UF_FIELD=UF_CRM_1743187724272

# Bitrix database replica (optional)
BITRIX_DB_HOST=localhost
BITRIX_DB_PORT=5432
BITRIX_DB_NAME=bitrix
BITRIX_DB_USER=bitrix_user
BITRIX_DB_PASSWORD=change_me
BITRIX_DB_SSL=disable

# Browser-level UI smoke for AI Analysis (optional)
AI_ANALYSIS_UI_SMOKE_BASE_URL=https://ai.irbistech.com
AI_ANALYSIS_UI_SMOKE_LOGIN=
AI_ANALYSIS_UI_SMOKE_PASSWORD=
AI_ANALYSIS_UI_SMOKE_HEADLESS=true
AI_ANALYSIS_UI_SMOKE_REQUIRE_AUTH=false
AI_ANALYSIS_UI_SMOKE_CAPTURE=true
AI_ANALYSIS_UI_SMOKE_ARTIFACT_DIR=artifacts/ai-analysis-ui-smoke

# Service-chain health smoke (optional)
LIBRARY_HEALTH_BASE_URL=https://ai.irbistech.com

# Standalone service-chain healthcheck for cron/systemd monitoring (optional)
LIBRARY_SYSTEM_HEALTH_URL=http://127.0.0.1:8090/api/health
LIBRARY_SYSTEM_HEALTH_TIMEOUT_MS=10000
LIBRARY_SYSTEM_HEALTH_ALERT_WEBHOOK_URL=
LIBRARY_SYSTEM_HEALTH_ALERT_ON_RECOVERY=true
LIBRARY_SYSTEM_HEALTH_STATE_FILE=/var/lib/library/library-system-health-state.json
